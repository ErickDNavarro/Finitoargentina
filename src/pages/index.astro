---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import ScrollProgressBar from '@/components/ScrollProgressBar.astro';
import Hero from '@/components/Hero.astro';
import Marquee from '@/components/Marquee.astro';
import ConsignacionSteps from '@/components/ConsignacionSteps.astro';
import PorQueFinito from '@/components/PorQueFinito.astro';
import Productos from '@/components/Productos.astro';
import ParaQuien from '@/components/ParaQuien.astro';
import LeadForm from '@/components/LeadForm.astro';
import Catering from '@/components/Catering.astro';
import SobreFinito from '@/components/SobreFinito.astro';
import SocialProof from '@/components/SocialProof.astro';
import Footer from '@/components/Footer.astro';
import WhatsappFloat from '@/components/WhatsappFloat.astro';
import ScrollReveal from '@/components/ScrollReveal.astro';
---

<Base>
  <ScrollProgressBar />
  <Header />
  <main id="contenido">
    <Hero />
    <Marquee />
    <ConsignacionSteps />
    <PorQueFinito />
    <Productos />
    <ParaQuien />
    <LeadForm />
    <Catering />
    <SobreFinito />
    <SocialProof />
  </main>
  <Footer />
  <WhatsappFloat />
  <ScrollReveal />
</Base>
