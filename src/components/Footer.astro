---
import logoHorizontal from '@/assets/brand/logo-horizontal.svg';
import { Image } from 'astro:assets';
import { publicEnv } from '@/lib/env';
import { whatsappLinks } from '@/lib/whatsapp';
import { footer } from '@/data/content';
import { businessInfo, areasMayorista, areasRetail } from '@/data/seo';
import { zonas } from '@/data/zonas';
import Icon from '@/components/Icon.astro';
---

<footer style="border-top: 1px solid var(--border-subtle); background: var(--color-eerie-950); padding-block: var(--space-8);">
  <div class="container-finito">
    <div class="grid grid-cols-1 md:grid-cols-[1.4fr_1fr_1fr_1fr] min-w-0" style="gap: var(--space-6);">
      <div>
        <Image
          src={logoHorizontal}
          alt="Finito Argentina"
          width={180}
          height={42}
          class="h-[38px] w-auto mb-[18px]"
        />
        <p style="color: var(--color-text-muted); font-size: 14px; max-width: 280px; margin: 0;">
          Tequeños venezolanos al por mayor. Para tu local o tu evento, en CABA y Zona Norte.
        </p>
        <div style="display: flex; gap: 10px; margin-top: 20px;">
          <a
            href={publicEnv.PUBLIC_INSTAGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram de Finito Argentina"
            style="width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--border-subtle); color: var(--color-text-secondary); display: inline-flex; align-items: center; justify-content: center;"
            data-analytics="footer-instagram"
          >
            <Icon name="instagram" size={18} />
          </a>
          <a
            href={whatsappLinks.general}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp de Finito Argentina"
            style="width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--border-subtle); color: var(--color-text-secondary); display: inline-flex; align-items: center; justify-content: center;"
            data-analytics="footer-whatsapp"
          >
            <Icon name="whatsapp" size={18} />
          </a>
        </div>
      </div>

      <div>
        <div style="font-family: var(--font-display); text-transform: uppercase; font-size: 13px; letter-spacing: 0.05em; margin-bottom: 16px; color: var(--color-text-primary);">Páginas</div>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px;">
          <li><a class="footer-link" href="/">Inicio</a></li>
          <li><a class="footer-link" href="/consignacion">Consignación · Sin riesgo</a></li>
          <li><a class="footer-link" href="/tequenos-congelados">Tequeños congelados</a></li>
          <li><a class="footer-link" href="/catering-eventos">Catering eventos</a></li>
          <li><a class="footer-link" href="/blog">Blog</a></li>
        </ul>
      </div>

      <div>
        <div style="font-family: var(--font-display); text-transform: uppercase; font-size: 13px; letter-spacing: 0.05em; margin-bottom: 16px; color: var(--color-text-primary);">Contacto</div>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 11px;">
          <li>
            <a
              class="footer-link"
              href={whatsappLinks.general}
              target="_blank"
              rel="noopener noreferrer"
            >
              +{publicEnv.PUBLIC_WHATSAPP_NUMBER}
            </a>
          </li>
          <li>
            <a
              class="footer-link"
              href={`mailto:${businessInfo.contactEmail}`}
            >
              {businessInfo.contactEmail}
            </a>
          </li>
          <li>
            <a
              class="footer-link"
              href={publicEnv.PUBLIC_INSTAGRAM_URL}
              target="_blank"
              rel="noopener noreferrer"
            >
              @finitoargentina
            </a>
          </li>
          <li><a class="footer-link" href="#formulario">Pedí cotización</a></li>
          <li style="color: var(--color-text-muted); font-size: 13px; padding-top: 8px; border-top: 1px solid var(--border-subtle); margin-top: 4px;">
            {businessInfo.hours.daysHuman}<br/>
            {businessInfo.hours.openHuman}
          </li>
        </ul>
      </div>

      <div>
        <div style="font-family: var(--font-display); text-transform: uppercase; font-size: 13px; letter-spacing: 0.05em; margin-bottom: 16px; color: var(--color-text-primary);">Zonas mayorista</div>
        <ul style="list-style: none; padding: 0; margin: 0 0 12px; display: flex; flex-direction: column; gap: 8px;">
          {zonas.map((z) => (
            <li>
              <a class="footer-link" href={`/tequenos-${z.slug}`}>Tequeños en {z.nombre}</a>
            </li>
          ))}
        </ul>
        <p style="color: var(--color-text-muted); font-size: 12px; margin: 12px 0 6px; line-height: 1.5; padding-top: 12px; border-top: 1px solid var(--border-subtle);">
          <strong style="color: var(--color-text-secondary);">+CABA</strong>: {areasMayorista.CABA.join(', ')}.
        </p>
        <p style="color: var(--color-text-muted); font-size: 12px; margin: 0 0 12px; line-height: 1.5;">
          <strong style="color: var(--color-text-secondary);">+Zona Norte</strong>: {areasMayorista.zonaNorte.join(', ')}.
        </p>
        <div style="font-family: var(--font-display); text-transform: uppercase; font-size: 11px; letter-spacing: 0.08em; margin-top: 14px; margin-bottom: 6px; color: var(--color-text-primary);">Retail · Particulares</div>
        <p style="color: var(--color-text-muted); font-size: 12px; margin: 0; line-height: 1.5;">
          Entrega directa en {areasRetail.join(', ')}.
        </p>
      </div>
    </div>

    <div style="margin-top: var(--space-7); padding-top: var(--space-5); border-top: 1px solid var(--border-subtle); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; color: var(--color-text-muted); font-size: 13px;">
      <span>{footer.copyright}</span>
      <span>Hecho en Pilar, Buenos Aires · con queso que estira de verdad</span>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    color: var(--color-text-secondary);
    font-size: 14px;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer-link:hover {
    color: var(--color-text-primary);
  }
</style>
