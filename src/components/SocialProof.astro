---
import { socialProof } from '@/data/content';
import Eyebrow from '@/components/Eyebrow.astro';
import Icon from '@/components/Icon.astro';

const hasTestimonios = socialProof.testimonios.length > 0;
---

{hasTestimonios && (
  <section id="testimonios" class="section section-alt">
    <div class="container-finito">
      <div class="section-head mx-auto reveal" style="text-align: center; align-items: center;">
        <div style="display: flex; justify-content: center;"><Eyebrow>{socialProof.eyebrow}</Eyebrow></div>
        <h2 style="text-align: center;">{socialProof.titulo}</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 min-w-0" style="gap: var(--space-5); margin-top: var(--space-7);">
        {socialProof.testimonios.map((t, i) => (
          <div class={`card reveal d${i + 1}`} style="display: flex; flex-direction: column; gap: 18px;">
            <div style="display: flex; gap: 3px; color: var(--color-accent);">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="star" size={16} />
              ))}
            </div>
            <p style="margin: 0; color: var(--color-text-primary); font-size: 16px; line-height: 1.55; font-weight: 500;">"{t.texto}"</p>
            <div style="display: flex; align-items: center; gap: 12px; margin-top: auto;">
              <span style="width: 42px; height: 42px; border-radius: 50%; background: var(--color-accent); color: var(--color-text-on-accent); display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 18px;">
                {t.nombre.charAt(0)}
              </span>
              <div>
                <div style="font-weight: 700; color: var(--color-text-primary); font-size: 14px;">{t.nombre}</div>
                <div style="font-size: 12px; color: var(--color-text-muted);">{t.negocio}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
