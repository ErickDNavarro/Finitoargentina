---
import { consignacion } from '@/data/content';
import { whatsappLinks } from '@/lib/whatsapp';
import Eyebrow from '@/components/Eyebrow.astro';
import Icon from '@/components/Icon.astro';

const comparativa = [
  {
    label: 'Con cualquier otro proveedor',
    items: [
      'Comprás stock antes de saber si rota',
      'Si no se vende, te lo comés vos',
      'Mínimos altos o precio caro, elegí',
    ],
    tone: 'negative' as const,
  },
  {
    label: 'Con Finito',
    items: [
      'El primer pedido va sin cobrar',
      'Vendés primero, pagás después',
      'Cero stock parado, cero deuda',
    ],
    tone: 'positive' as const,
  },
];
---

<section id="consignacion" class="section section-alt relative overflow-hidden">
  <div class="glow-blob" style="width: 600px; height: 600px; background: rgba(251,176,59,0.10); top: -80px; left: 50%; transform: translateX(-50%);"></div>

  <div class="container-finito relative z-[1]">
    <div class="section-head mx-auto reveal" style="text-align: center; align-items: center;">
      <div style="display: flex; justify-content: center;"><Eyebrow>{consignacion.eyebrow}</Eyebrow></div>
      <h2 style="text-align: center; font-size: var(--fs-display); line-height: 1; max-width: 18ch;">
        Probá Finito <span class="text-shimmer">sin poner</span> un peso
      </h2>
      <p style="text-align: center; max-width: 640px;">
        {consignacion.subtitulo}
      </p>
    </div>

    {/* Pasos */}
    <ol class="grid md:grid-cols-3 list-none p-0" style="gap: var(--space-5); margin: var(--space-8) 0 0;">
      {consignacion.pasos.map((paso, i) => (
        <li class={`reveal d${i + 1}`}>
          <div class="card h-full">
            <div style="font-family: var(--font-display); font-size: 14px; color: var(--color-accent); letter-spacing: 0.1em;">
              0{paso.n}
            </div>
            <h3 style="font-family: var(--font-display); text-transform: uppercase; font-size: 19px; margin: 12px 0 12px; color: var(--color-text-primary); line-height: 1.18;">
              {paso.titulo}
            </h3>
            <p style="margin: 0; color: var(--color-text-secondary); font-size: 15px; line-height: 1.55;">{paso.descripcion}</p>
          </div>
        </li>
      ))}
    </ol>

    {/* Comparativa */}
    <div class="reveal" style="margin-top: var(--space-9); max-width: 920px; margin-inline: auto;">
      <h3 style="text-align: center; font-family: var(--font-display); text-transform: uppercase; font-size: 22px; margin: 0 0 var(--space-6); color: var(--color-text-primary);">
        Lo que cambia <span style="color: var(--color-accent);">en la práctica</span>
      </h3>
      <div class="grid md:grid-cols-2" style="gap: var(--space-4);">
        {comparativa.map((col) => (
          <div
            class="card"
            style={`position: relative; ${col.tone === 'positive' ? 'border-color: rgba(251,176,59,0.35); background: linear-gradient(180deg, rgba(251,176,59,0.06), var(--color-surface-card));' : 'opacity: 0.85;'}`}
          >
            {col.tone === 'positive' && (
              <span class="badge badge-accent" style="position: absolute; top: 14px; right: 14px;">Así</span>
            )}
            <div class="overline" style={`margin-bottom: var(--space-4); ${col.tone === 'positive' ? 'color: var(--color-accent);' : ''}`}>
              {col.label}
            </div>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
              {col.items.map((it) => (
                <li style="display: flex; align-items: flex-start; gap: 12px; color: var(--color-text-primary); font-size: 15px;">
                  <span
                    style={`flex: none; width: 24px; height: 24px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; ${col.tone === 'positive' ? 'background: var(--orange-glow); color: var(--color-accent);' : 'background: rgba(224,83,61,0.12); color: var(--color-danger);'}`}
                  >
                    {col.tone === 'positive' ? <Icon name="check" size={14} /> : (
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                      </svg>
                    )}
                  </span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    {/* CTAs */}
    <div class="reveal flex flex-wrap" style="justify-content: center; gap: var(--space-3); margin-top: var(--space-8);">
      <a href="#formulario" class="btn btn-primary btn-lg" data-analytics="consignacion-cta-revendedor">
        Quiero probar sin riesgo
        <Icon name="arrow-right" size={18} />
      </a>
      <a
        href={whatsappLinks.revendedor}
        class="btn btn-whatsapp btn-lg"
        target="_blank"
        rel="noopener noreferrer"
        data-analytics="consignacion-cta-whatsapp"
      >
        <Icon name="whatsapp" size={20} />
        Hablar por WhatsApp
      </a>
    </div>
  </div>
</section>
