---
import '@/styles/global.css';
import { publicEnv } from '@/lib/env';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = 'Finito Argentina · Tequeños venezolanos mayoristas para tu carta',
  description = 'Tequeños venezolanos auténticos para restaurantes, bares y eventos en CABA y Zona Norte. Primer pedido a consignación, sin riesgo. Consultá por WhatsApp.',
  ogImage = '/og-image.svg',
  canonical,
} = Astro.props;

const siteUrl = publicEnv.PUBLIC_SITE_URL;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Finito Argentina',
  description,
  url: siteUrl,
  image: ogImageUrl,
  telephone: `+${publicEnv.PUBLIC_WHATSAPP_NUMBER}`,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Buenos Aires',
    addressRegion: 'CABA y Zona Norte',
    addressCountry: 'AR',
  },
  areaServed: ['Buenos Aires', 'CABA', 'Zona Norte GBA'],
  sameAs: [publicEnv.PUBLIC_INSTAGRAM_URL],
};
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1A1A1A" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="tequeños mayorista, proveedor tequeños Buenos Aires, tequeños venezolanos por mayor, tequeños CABA, catering tequeños, revendedor tequeños" />
    <meta name="author" content="Finito Argentina" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Finito Argentina" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD LocalBusiness -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen bg-background text-text-primary">
    <a
      href="#contenido"
      class="absolute left-2 top-2 z-50 -translate-y-20 rounded bg-orange-brand px-3 py-2 text-on-primary font-display font-bold transition-transform focus:translate-y-0"
    >
      Saltar al contenido
    </a>
    <slot />
  </body>
</html>
